# Codi 环境变量配置

# ---- acestep.cpp 服务配置 ----
ACE_SERVER_URL=http://127.0.0.1:8085
ACE_LM_MODEL=acestep-5Hz-lm-4B-Q5_K_M.gguf
ACE_SYNTH_MODEL=acestep-v15-turbo-Q4_K_M.gguf

# 推理参数（8GB 显存优化）
ACE_INFERENCE_STEPS=8
ACE_GUIDANCE_SCALE=1.0
ACE_SHIFT=3.0
ACE_DURATION=180

# ---- FastAPI 服务配置 ----
CODI_OUTPUT=./output
DATABASE_URL=sqlite+aiosqlite:///./codi.db

# ---- 微信支付配置（正式环境需填写）----
# WX_APPID=
# WX_MCHID=
# WX_APIV3_KEY=
# WX_CERT_SERIAL_NO=
# WX_PRIVATE_KEY_PATH=
