.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.hero-icon { font-size: 96rpx; margin-bottom: 32rpx; }

.hero-title {
  font-size: 52rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.hero-desc {
  font-size: 28rpx;
  color: #808090;
  text-align: center;
  line-height: 1.6;
}

.demo-row {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.demo-label { font-size: 24rpx; color: #a0a0b0; }

.pricing {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin: 40rpx 0;
  padding: 0 16rpx;
}

.price-card {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.price-card.active {
  border-color: #e94560;
  background: rgba(233,69,96,0.12);
}

.price-amount { font-size: 48rpx; font-weight: 500; }
.price-label { font-size: 26rpx; margin: 8rpx 0; }
.price-desc { font-size: 22rpx; color: #808090; }

.styles-preview { width: 100%; margin: 40rpx 0 80rpx; }
.section-title { font-size: 26rpx; color: #808090; margin-bottom: 20rpx; display: block; }

.style-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #c0c0d0;
}
