<view class="container">
  <view class="hero">
    <text class="hero-icon">🎵</text>
    <text class="hero-title">用AI为ta写一首歌</text>
    <text class="hero-desc">选风格 · 说心情 · 扫码付 \n 几分钟拿到属于你们的歌</text>
  </view>

  <view class="demo-row">
    <text class="demo-label">今天有人为他们的婚礼</text>
    <text class="demo-label">创作了一首中国风歌曲</text>
    <text class="demo-label">💍</text>
  </view>

  <button class="btn-primary" bindtap="goCreate">开始定制</button>

  <view class="pricing">
    <view class="price-card {{selectedTier === 'basic' ? 'active' : ''}}" bindtap="selectTier" data-tier="basic">
      <text class="price-amount">¥5</text>
      <text class="price-label">基础版</text>
      <text class="price-desc">MP4 · 带歌词</text>
    </view>
    <view class="price-card {{selectedTier === 'premium' ? 'active' : ''}}" bindtap="selectTier" data-tier="premium">
      <text class="price-amount">¥8</text>
      <text class="price-label">完整版</text>
      <text class="price-desc">MP4 · 歌词 · 曲谱</text>
    </view>
  </view>

  <view class="styles-preview">
    <text class="section-title">可选风格</text>
    <view class="style-chips">
      <text class="chip" wx:for="{{styles}}" wx:key="key">{{item.name}}</text>
    </view>
  </view>
</view>
