<view class="container">
  <!-- 进度指示器 -->
  <view class="progress-bar">
    <view class="progress-step {{step >= 1 ? 'done' : ''}} {{step === 1 ? 'active' : ''}}">
      <text class="step-num">1</text>
      <text class="step-label">听众</text>
    </view>
    <view class="progress-line {{step >= 2 ? 'done' : ''}}"></view>
    <view class="progress-step {{step >= 2 ? 'done' : ''}} {{step === 2 ? 'active' : ''}}">
      <text class="step-num">2</text>
      <text class="step-label">心情</text>
    </view>
    <view class="progress-line {{step >= 3 ? 'done' : ''}}"></view>
    <view class="progress-step {{step >= 3 ? 'done' : ''}} {{step === 3 ? 'active' : ''}}">
      <text class="step-num">3</text>
      <text class="step-label">风格</text>
    </view>
  </view>

  <!-- 第一步：这是给谁的 -->
  <view class="step-body" wx:if="{{step === 1}}">
    <text class="step-question">这首歌是给谁的？</text>

    <view class="option-grid">
      <view class="option-card {{audience === 'lover' ? 'selected' : ''}}" bindtap="selectAudience" data-key="lover">
        <text class="option-icon">💕</text>
        <text class="option-name">恋人</text>
        <text class="option-hint">送给你爱的人</text>
      </view>
      <view class="option-card {{audience === 'friend' ? 'selected' : ''}}" bindtap="selectAudience" data-key="friend">
        <text class="option-icon">🤝</text>
        <text class="option-name">朋友</text>
        <text class="option-hint">送给兄弟或闺蜜</text>
      </view>
      <view class="option-card {{audience === 'family' ? 'selected' : ''}}" bindtap="selectAudience" data-key="family">
        <text class="option-icon">🏠</text>
        <text class="option-name">家人</text>
        <text class="option-hint">送给父母或亲人</text>
      </view>
      <view class="option-card {{audience === 'self' ? 'selected' : ''}}" bindtap="selectAudience" data-key="self">
        <text class="option-icon">🌟</text>
        <text class="option-name">自己</text>
        <text class="option-hint">为努力的自己</text>
      </view>
      <view class="option-card {{audience === 'colleague' ? 'selected' : ''}}" bindtap="selectAudience" data-key="colleague">
        <text class="option-icon">💼</text>
        <text class="option-name">同事</text>
        <text class="option-hint">年会或项目庆祝</text>
      </view>
    </view>

    <button class="btn-primary next-btn" bindtap="nextStep" disabled="{{!audience}}">
      下一步
    </button>
  </view>

  <!-- 第二步：什么心情 / 什么场合 -->
  <view class="step-body" wx:if="{{step === 2}}">
    <text class="step-question">这首歌用在什么场合？</text>

    <view class="occasion-list">
      <view class="occasion-item {{occasion === 'love' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="love">
        <text class="occasion-text">❤️ 表白 / 表达爱意</text>
      </view>
      <view class="occasion-item {{occasion === 'proposal' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="proposal">
        <text class="occasion-text">💍 求婚</text>
      </view>
      <view class="occasion-item {{occasion === 'wedding' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="wedding">
        <text class="occasion-text">💒 婚礼 / 纪念日</text>
      </view>
      <view class="occasion-item {{occasion === 'birthday' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="birthday">
        <text class="occasion-text">🎂 生日</text>
      </view>
      <view class="occasion-item {{occasion === 'graduation' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="graduation">
        <text class="occasion-text">🎓 毕业</text>
      </view>
      <view class="occasion-item {{occasion === 'missing' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="missing">
        <text class="occasion-text">🌙 思念 / 异地</text>
      </view>
      <view class="occasion-item {{occasion === 'encourage' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="encourage">
        <text class="occasion-text">💪 加油打气</text>
      </view>
      <view class="occasion-item {{occasion === 'thanks' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="thanks">
        <text class="occasion-text">🙏 感谢</text>
      </view>
      <view class="occasion-item {{occasion === 'new_year' ? 'selected' : ''}}" bindtap="selectOccasion" data-key="new_year">
        <text class="occasion-text">🎉 年会 / 新年</text>
      </view>
    </view>

    <button class="btn-primary next-btn" bindtap="nextStep" disabled="{{!occasion}}">
      下一步
    </button>
    <button class="btn-secondary next-btn" bindtap="prevStep">上一步</button>
  </view>

  <!-- 第三步：选风格 + 特别的话 -->
  <view class="step-body" wx:if="{{step === 3}}">
    <text class="step-question">选一个风格</text>

    <view class="style-grid">
      <view class="style-chip {{style === item.key ? 'selected' : ''}}" wx:for="{{styles}}" wx:key="key" bindtap="selectStyle" data-key="{{item.key}}">
        <text>{{item.name}}</text>
      </view>
    </view>

    <text class="step-question" style="margin-top: 48rpx;">有什么特别的话想加进去？</text>
    <text class="input-hint">比如TA的喜好、你们的回忆、特定的地名或人名（选填）</text>

    <textarea class="personal-input" placeholder="比如：她喜欢向日葵，我们在贵州认识的..."
              placeholder-class="input-placeholder"
              maxlength="200"
              bindinput="onNoteInput"
              value="{{personalNote}}">
    </textarea>

    <button class="btn-primary next-btn" bindtap="previewAndPay" disabled="{{!style}}">
      确认，付¥{{tier === 'premium' ? '8' : '5'}}
    </button>
    <button class="btn-secondary next-btn" bindtap="prevStep">上一步</button>
  </view>
</view>
