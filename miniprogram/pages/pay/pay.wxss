.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 48rpx 32rpx;
}

.pay-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 80rpx 0 60rpx;
}

.pay-icon { font-size: 96rpx; margin-bottom: 32rpx; }
.pay-title { font-size: 36rpx; color: #a0a0b0; margin-bottom: 16rpx; }
.pay-price { font-size: 80rpx; font-weight: 500; color: #e94560; }

.pay-detail {
  width: 100%;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 80rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
}

.detail-label { font-size: 28rpx; color: #808090; }
.detail-value { font-size: 28rpx; }

.pay-btn { margin-bottom: 32rpx; }
.tip { font-size: 24rpx; color: #505060; text-align: center; }
