<view class="container">
  <!-- 生成中状态 -->
  <view class="generating" wx:if="{{status === 'generating' || status === 'paid'}}">
    <view class="loader-ring"></view>
    <text class="gen-title">正在为你创作...</text>
    <text class="gen-desc">AI正在谱写旋律、编排歌词</text>
    <text class="gen-elapsed">已等待 {{elapsed}} 秒</text>
  </view>

  <!-- 完成状态 -->
  <view class="done" wx:if="{{status === 'completed'}}">
    <text class="done-icon">✨</text>
    <text class="done-title">你的歌已经创作完成</text>

    <!-- 视频播放 / 预览 -->
    <view class="video-box" bindtap="previewVideo">
      <text class="play-btn">▶</text>
      <text class="play-label">点击播放</text>
    </view>

    <!-- 歌词预览 -->
    <view class="lyrics-preview">
      <text class="section-label">歌词预览</text>
      <text class="lyrics-text">{{lyrics}}</text>
    </view>

    <button class="btn-primary" bindtap="downloadVideo">
      下载 MP4 视频
    </button>

    <button class="btn-secondary" wx:if="{{tier === 'premium'}}" bindtap="downloadSheet">
      下载曲谱
    </button>

    <button class="btn-secondary" bindtap="shareSong">
      分享给朋友
    </button>
  </view>

  <!-- 失败状态 -->
  <view class="failed" wx:if="{{status === 'failed'}}">
    <text class="fail-icon">😟</text>
    <text class="fail-title">生成失败</text>
    <text class="fail-msg">{{errorMsg}}</text>
    <button class="btn-primary" bindtap="retry">重新生成</button>
  </view>
</view>
