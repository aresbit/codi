.container {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 生成中 */
.generating {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
}

.loader-ring {
  width: 100rpx;
  height: 100rpx;
  border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: #e94560;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 48rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.gen-title { font-size: 36rpx; font-weight: 500; margin-bottom: 16rpx; }
.gen-desc { font-size: 26rpx; color: #808090; margin-bottom: 24rpx; }
.gen-elapsed { font-size: 24rpx; color: #505060; }

/* 完成 */
.done {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 64rpx;
}

.done-icon { font-size: 96rpx; margin-bottom: 32rpx; }
.done-title { font-size: 40rpx; font-weight: 500; margin-bottom: 48rpx; }

.video-box {
  width: 100%;
  aspect-ratio: 9/16;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.play-btn { font-size: 72rpx; margin-bottom: 16rpx; }
.play-label { font-size: 26rpx; color: #808090; }

.lyrics-preview {
  width: 100%;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.section-label { font-size: 24rpx; color: #606070; display: block; margin-bottom: 16rpx; }
.lyrics-text { font-size: 28rpx; line-height: 1.8; white-space: pre-wrap; }

.done .btn-primary, .done .btn-secondary {
  width: 100%;
  margin-bottom: 20rpx;
}

/* 失败 */
.failed {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
}

.fail-icon { font-size: 96rpx; margin-bottom: 32rpx; }
.fail-title { font-size: 36rpx; margin-bottom: 16rpx; }
.fail-msg { font-size: 26rpx; color: #808090; margin-bottom: 48rpx; text-align: center; }
