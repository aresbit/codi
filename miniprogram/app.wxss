page {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  min-height: 100vh;
  padding: 40rpx 32rpx;
}

.btn-primary {
  background: #e94560;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  text-align: center;
  width: 100%;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  background: transparent;
  color: #a0a0b0;
  border: 1px solid #333;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
}
